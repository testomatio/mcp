# Testomatio MCP configuration
# Copy this file to .env and fill in your project credentials.

# Required: project token from Testomat project settings.
# Preferred variable name:
TESTOMATIO_PROJECT_TOKEN=tstmt_your_project_token_here
# Backward-compatible alias also supported by loader:
# TESTOMATIO_API_TOKEN=tstmt_your_project_token_here

# Required: project public ID/slug.
TESTOMATIO_PROJECT_ID=your_project_id_here

# Optional: API host.
# Default: https://app.testomat.io
# Use beta when needed:
# TESTOMATIO_BASE_URL=https://beta.testomat.io
