  "/api/v2/{project_id}/issues":
    get:
      summary: List linked issues
      operationId: listIssues
      tags:
      - Issues
      parameters:
      - "$ref": "#/components/parameters/projectId"
      - "$ref": "#/components/parameters/page"
      - "$ref": "#/components/parameters/perPage"
      - name: test_id
        in: query
        description: Filter by test (public UID)
        schema:
          type: string
      - name: suite_id
        in: query
        description: Filter by suite (public UID)
        schema:
          type: string
      - name: run_id
        in: query
        description: Filter by run (public UID)
        schema:
          type: string
      - name: testrun_id
        in: query
        description: Filter by testrun (integer ID)
        schema:
          type: integer
      - name: plan_id
        in: query
        description: Filter by plan (public UID)
        schema:
          type: string
      - name: source
        in: query
        description: Filter by source (e.g. jira, github, linear, link)
        schema:
          type: string
      responses:
        '200':
          description: Paginated list of issues
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    type: array
                    items:
                      "$ref": "#/components/schemas/Issue"
                  meta:
                    "$ref": "#/components/schemas/PaginationMeta"
        '401':
          "$ref": "#/components/responses/Unauthorized"
    post:
      summary: Link an issue to a resource
      operationId: createIssue
      tags:
      - Issues
      parameters:
      - "$ref": "#/components/parameters/projectId"
      - name: test_id
        in: query
        description: Public UID of the test to link
        schema:
          type: string
      - name: suite_id
        in: query
        description: Public UID of the suite to link
        schema:
          type: string
      - name: run_id
        in: query
        description: Public UID of the run to link
        schema:
          type: string
      - name: testrun_id
        in: query
        description: ID of the testrun to link
        schema:
          type: integer
      - name: plan_id
        in: query
        description: Public UID of the plan to link
        schema:
          type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
              - issue
              properties:
                issue:
                  "$ref": "#/components/schemas/IssueInput"
      responses:
        '201':
          description: Issue linked
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    "$ref": "#/components/schemas/Issue"
        '422':
          "$ref": "#/components/responses/UnprocessableEntity"
  "/api/v2/{project_id}/issues/{id}":
    delete:
      summary: Unlink an issue
      operationId: deleteIssue
      tags:
      - Issues
      parameters:
      - "$ref": "#/components/parameters/projectId"
      - name: id
        in: path
        required: true
        description: Database ID of the issue
        schema:
          type: integer
      - name: type
        in: query
        required: true
        description: 'Type of issue: ''issue'' or ''jira_issue'''
        schema:
          type: string
          enum:
          - issue
          - jira_issue
      responses:
        '204':
          description: Issue unlinked
        '404':
          "$ref": "#/components/responses/NotFound"

